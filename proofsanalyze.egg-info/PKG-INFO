│   │   │
│   │   ├── agents/
│   │   │   ├── formulator_agent.py          # Агент-Формулировщик
│   │   │   └── critic_agent.py              # Агент-Критик
│   │   │
│   │   └── clients/
│   │       └── db/
│   │           └── rag/
│   │               ├── build.py             # Построение RAG-базы
│   │               └── ...                  # RAG-слой / векторный поиск
│   │
│   ├── services/
